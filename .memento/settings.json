{
  "enforcement_config": {
    "level1": true,
    "level2": true,
    "level3": true
  },
  "active_coercion": {
    "enabled": true,
    "rules": [
      {
        "id": "no_console_log",
        "enabled": true,
        "path_globs": [
          "**/*.py",
          "**/*.ts"
        ],
        "regex": "\\b(print|console\\.log)\\(",
        "message": "Usa logger strutturati, non console.log o print.",
        "severity": "block",
        "override_token": "memento-override"
      }
    ]
  }
}